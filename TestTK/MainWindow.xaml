<Window x:Class="TestTK.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestTK"
        mc:Ignorable="d"
        Title="Стоимость проезда ж/д транспортом" Height="350" Width="800">
    <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="2*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Расстояние (км)" FontSize="18" Margin="10,30,10,10" Height="25"></TextBlock>
            <TextBlock Text="Количество билетов" FontSize="18" Margin="10" Height="25"></TextBlock>
        </StackPanel>
        <StackPanel Grid.Column="1">
            <TextBox x:Name="TB_dist" Margin="10,30,10,10" Height="25" PreviewTextInput="TextBox_PreviewTextInput"></TextBox>
            <TextBox x:Name="TB_kol" Margin="10" Height="25" PreviewTextInput="TextBox_PreviewTextInput"></TextBox>
        </StackPanel>
        <Viewbox MinHeight="150" MinWidth="200" Grid.Column="2" VerticalAlignment="Top" Margin="30" HorizontalAlignment="Left">
            <GroupBox Width="200" Header="Комфортабельность">
                <StackPanel>
                    <RadioButton Content="плацкарт" Margin="5" Checked="RadioButton_Checked"/>
                    <RadioButton Content="купе" Margin="5" Checked="RadioButton_Checked"/>
                    <RadioButton Content="полулюкс" Margin="5" Checked="RadioButton_Checked"/>
                    <RadioButton Content="люкс" Margin="5" Checked="RadioButton_Checked"/>
                </StackPanel>
            </GroupBox>
        </Viewbox>
        <Button Grid.Column="2" Grid.Row="1" Height="40" Width="150" Content="Вычислить" FontSize="18" Margin="30" HorizontalAlignment="Left" Click="Button_Click"></Button>
        <TextBlock Name="TB_result" Grid.ColumnSpan="2" Grid.Row="3" Text="Стоимость билетов с учетом комфортабельности" FontSize="24" TextWrapping="Wrap"></TextBlock>
    </Grid>
</Window>
